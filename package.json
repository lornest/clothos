{
  "name": "clothos",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "repl": "tsx scripts/repl.mts",
    "start": "node packages/app/dist/main.js",
    "build:sandbox": "docker compose -f docker/docker-compose.yml build sandbox"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ],
    "patchedDependencies": {
      "@whiskeysockets/baileys@6.17.16": "patches/@whiskeysockets__baileys@6.17.16.patch"
    }
  },
  "devDependencies": {
    "@clothos/agent-runtime": "workspace:*",
    "knip": "^5.84.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3"
  }
}
